{
  "name": "@mina/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    }
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun run typecheck && bun build src/index.ts --outdir dist --target bun",
    "db:create": "bun scripts/db/create-database.ts",
    "db:drop": "bun scripts/db/drop-database.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migration:test": "bun run db:drop && bun run db:create && bun run db:generate && bun run db:migrate",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:reset": "bun scripts/db/reset.ts",
    "db:reset:push": "bun run db:reset && bun run db:push",
    "db:seed": "bun src/db/seed.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "NODE_ENV=test MINA_STORAGE_DRIVER=s3 bun test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@aws-sdk/s3-request-presigner": "catalog:",
    "@hono/standard-validator": "catalog:",
    "@hono/zod-openapi": "^1.4.0",
    "@mina/contracts": "workspace:*",
    "@scalar/hono-api-reference": "^0.10.16",
    "@t3-oss/env-core": "catalog:",
    "croner": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "pino": "catalog:",
    "postgres": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@mina/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:"
  }
}
