{
  "name": "mina",
  "private": true,
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.11 <1.4.0"
  },
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "catalog": {
      "@aws-sdk/client-s3": "3.1045.0",
      "@aws-sdk/s3-request-presigner": "3.1045.0",
      "@base-ui/react": "^1.4.1",
      "@hono/standard-validator": "^0.2.2",
      "@inlang/paraglide-js": "2.18.1",
      "@t3-oss/env-core": "^0.13.11",
      "@tanstack/react-query": "^5.95.2",
      "@tailwindcss/vite": "^4.3.0",
      "@types/bun": "~1.3.13",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^6.0.1",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "cmdk": "^1.1.1",
      "croner": "^10.0.1",
      "date-fns": "^4.1.0",
      "dotenv": "^17.4.2",
      "drizzle-kit": "1.0.0-rc.2",
      "drizzle-orm": "1.0.0-rc.2",
      "embla-carousel-react": "^8.6.0",
      "hono": "^4.12.9",
      "input-otp": "^1.4.2",
      "lucide-react": "^1.14.0",
      "next-themes": "^0.4.6",
      "pino": "^10.3.1",
      "postgres": "^3.4.9",
      "radix-ui": "^1.4.3",
      "react": "^19.2.4",
      "react-day-picker": "^10.0.0",
      "react-dom": "^19.2.4",
      "react-resizable-panels": "^4.11.0",
      "recharts": "^3.8.1",
      "sonner": "^2.0.7",
      "tailwind-merge": "^3.6.0",
      "tailwindcss": "^4.3.0",
      "tw-animate-css": "^1.4.0",
      "typescript": "^6.0.2",
      "vaul": "^1.1.2",
      "vite": "^8.0.3",
      "zod": "^4.3.6"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "playwright test",
    "i18n:compile": "bun --filter @mina/i18n i18n:compile",
    "check": "bun run typecheck && bun run test && bun run build",
    "dev:api": "bun --filter @mina/api dev",
    "dev:web": "bun --filter @mina/web dev",
    "build:api": "bun --filter @mina/api build",
    "build:web": "bun --filter @mina/web build",
    "typecheck:api": "bun --filter @mina/api typecheck",
    "typecheck:web": "bun --filter @mina/web typecheck",
    "typecheck:contracts": "bun --filter @mina/contracts typecheck",
    "check:boundaries": "bun scripts/check-api-boundaries.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "turbo": "^2.8.21"
  }
}
