MINA_API_PORT=3001
MINA_ALLOWED_ORIGIN=http://localhost:3000
MINA_LOG_LEVEL=info
MINA_PERSISTENCE_DRIVER=memory
MINA_DATABASE_URL=postgres://postgres:postgres@localhost:5432/mina
MINA_SCHEDULER_CRON="*/5 * * * * *"
MINA_SCHEDULER_ENABLED=false
MINA_STORAGE_DRIVER=memory
MINA_STORAGE_ROOT_PREFIX=users
MINA_TASK_MAX_RUNNING_SECONDS=21600
MINA_TASK_POLL_BATCH_SIZE=25
MINA_TASK_POLL_DEFAULT_INTERVAL_SECONDS=10
MINA_TASK_POLL_LEASE_SECONDS=30
MINA_TASK_POLL_MAX_INTERVAL_SECONDS=120
MINA_TASK_PROVIDER_ERROR_MAX_RETRIES=8
MINA_S3_REGION=us-east-1
MINA_S3_BUCKET=
MINA_S3_ENDPOINT=
MINA_S3_ACCESS_KEY_ID=
MINA_S3_SECRET_ACCESS_KEY=
MINA_S3_FORCE_PATH_STYLE=false
MINA_S3_PUBLIC_BASE_URL=
VITE_API_BASE_URL=/
