{
  "name": "@mina/i18n",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./messages": {
      "types": "./src/paraglide/messages.d.ts",
      "default": "./src/paraglide/messages.js"
    },
    "./runtime": {
      "types": "./src/paraglide/runtime.d.ts",
      "default": "./src/paraglide/runtime.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    }
  },
  "scripts": {
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --emit-ts-declarations --output-structure locale-modules --strategy baseLocale --is-server 'typeof window === \"undefined\"'",
    "build": "bun run i18n:compile && tsc -p tsconfig.json",
    "typecheck": "bun run i18n:compile && tsc --noEmit -p tsconfig.json",
    "test": "bun run i18n:compile && bun test"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "catalog:",
    "@mina/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  }
}
